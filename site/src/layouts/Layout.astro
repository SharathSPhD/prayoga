---
import '@/styles/global.css';

interface Props {
  title?: string;
}

const { title = 'prayoga' } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="prayoga: LLM Jailbreak, Hypnosis, Vaśīkaraṇa – Mechanistic Interpretability & Falsifiable Metaphor" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title} – prayoga</title>

    <!-- Google Fonts: Inter (sans) & Noto Serif Display (serif) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Serif+Display:wght@400;700&display=swap" rel="stylesheet" />

    <!-- KaTeX: CSS + auto-render -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css" integrity="sha384-GvrOXuhMATgEsSwCs4smul75gNUtUEKcPNgIQj7gv4cvC+xY/ALR0zsTBQagM0dYY" crossorigin="anonymous" />
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js" integrity="sha384-cpW21h6j7eJLu5HS+EmPrE3rBkbNBV8O6kqAP8kjlHw61sgQGio3+KzKeZD00lS4" crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/contrib/auto-render.min.js" integrity="sha384-+VBxd3r6XgURycqtZ9YV27akoSISxNAh7IQn76PwbaZM/33R90mxFF5fFyx6srQr" crossorigin="anonymous" onload="renderMathInElement(document.body, {delimiters: [{left: '$$', right: '$$', display: true}, {left: '$', right: '$', display: false}]});"></script>
  </head>
  <body class="bg-slate-950 text-slate-100 antialiased">
    <slot />
  </body>
</html>
