---
import Layout from '../layouts/Layout.astro';
import ParticleBrain from '../components/charts/ParticleBrain';
import DoseResponseChart from '../components/charts/DoseResponseChart';
import DimensionChart from '../components/charts/DimensionChart';
import SymmetryChart from '../components/charts/SymmetryChart';
import SatkarmaTable from '../components/charts/SatkarmaTable';
import FindingsExplorer from '../components/charts/FindingsExplorer';
import TierMatrix from '../components/ui/TierMatrix.astro';
import TierBadge from '../components/ui/TierBadge.astro';
import VerdictBadge from '../components/ui/VerdictBadge.astro';
import { AUTHOR, socialLinks } from '../data/author';

import findingsData from '../data/findings.json';
import metricsData from '../data/metrics.json';

const findings = findingsData.findings;
const metrics = metricsData;
---

<Layout title="prayoga | LLM Jailbreak, Hypnosis, Vaśīkaraṇa">
  {/* Hero */}
  <section id="hero" class="hero">
    <div class="hero-canvas">
      <ParticleBrain client:visible height={560} />
    </div>
    <div class="hero-copy reading">
      <p class="kicker">Interactive Research · Mechanistic Interpretability</p>
      <h1>Asymmetry with a Shared Necessary Core</h1>
      <p class="lead">
        LLM jailbreak, hypnotic suggestion, and tantric vaśīkaraṇa are three instances of ONE mechanism — capturing a system's output policy by injecting context that suppresses its monitoring/refusal faculty while co-opting automatic generation.
      </p>
      <p class="byline">by <strong>{AUTHOR.name}</strong> · a guided tour for the curious and the technical alike</p>
      <p class="scroll-hint" aria-hidden="true">scroll to begin ↓</p>
    </div>
  </section>

  {/* Thesis */}
  <section id="thesis" class="section-standard">
    <div class="reading wide">
      <h2>The Three-Tier Thesis</h2>
      <p class="lead">
        Refusal suppression is ONE mechanism at the necessary/ablatable level (transfers universally); it is MANY at the sufficient/dimensional level (model-specific).
      </p>
      <div class="triptych">
        <div class="triptych-panel">
          <h3>Jailbreak</h3>
          <p>Injecting context that suppresses the monitoring faculty while co-opting generation.</p>
        </div>
        <div class="triptych-panel">
          <h3>Hypnosis</h3>
          <p>Norman–Shallice SAS suppression: focused attention narrowing + SAS suppression.</p>
        </div>
        <div class="triptych-panel">
          <h3>Vaśīkaraṇa</h3>
          <p>Tantric: feminine power to capture output policy by suppressing monitoring.</p>
        </div>
      </div>
    </div>
  </section>

  {/* Mechanism */}
  <section id="mechanism" class="section-standard">
    <div class="reading wide">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
        <h2 style="margin: 0;">Mechanism Tier</h2>
        <TierBadge tier="MECHANISM" />
      </div>
      <p class="lead">Refusal is a low-dimensional, causally efficacious direction in the residual stream.</p>
      <div style="margin-top: 2rem; background: var(--bg-panel); padding: 2rem; border-radius: 8px; aspect-ratio: 16/9; min-height: 300px;">
        <DoseResponseChart client:visible data={metrics.dose} />
      </div>
      <p style="font-size: 0.95rem; color: var(--ink-faint); margin-top: 1rem;">
        <strong>F2: Dose–Response EC50 = 0.329, R² = 0.996.</strong> Refusal is a continuous sigmoidal function of direction removal.
      </p>
      <div style="margin-top: 3rem; background: var(--bg-panel); padding: 2rem; border-radius: 8px; aspect-ratio: 16/10; min-height: 350px;">
        <DimensionChart client:visible data={metrics.dimsweep} />
      </div>
      <p style="font-size: 0.95rem; color: var(--ink-faint); margin-top: 1rem;">
        <strong>F8 & F18: Layer-Dependent Dimensionality.</strong> Gemma 1D, Qwen 3D. Dimensionality is the discriminating quantity.
      </p>
    </div>
  </section>

  {/* Symmetry */}
  <section id="symmetry" class="section-standard">
    <div class="reading wide">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
        <h2 style="margin: 0;">Symmetry as Invariant</h2>
        <TierBadge tier="MECHANISM" />
      </div>
      <p class="lead">Refusal is a paraphrase-orbit symmetry invariant. Injection breaks it.</p>
      <div style="margin-top: 2rem; background: var(--bg-panel); padding: 2rem; border-radius: 8px; aspect-ratio: 16/9; min-height: 320px;">
        <SymmetryChart client:visible data={metrics.symmetry} />
      </div>
      <p style="font-size: 0.95rem; color: var(--ink-faint); margin-top: 1.5rem;">
        <strong>F11:</strong> F-ratio 19.2 vs random 0.65. Injection reduces order parameter m by 34% (Gemma), 45% (Qwen).
      </p>
    </div>
  </section>

  {/* Satkarma */}
  <section id="satkarma" class="section-standard">
    <div class="reading wide">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
        <h2 style="margin: 0;">ṣaṭkarma: Six Acts</h2>
        <TierBadge tier="METAPHOR" />
      </div>
      <p class="lead">Tantric intervention taxonomy. Three acts control-separate cleanly.</p>
      <div style="margin-top: 2rem; background: var(--bg-panel); padding: 2rem; border-radius: 8px;">
        <SatkarmaTable client:visible data={metrics.satkarma} />
      </div>
      <p style="font-size: 0.95rem; color: var(--ink-faint); margin-top: 1.5rem;">
        <strong>F10 & F14:</strong> Refusal acts (vaśīkaraṇa=ablate, śānti=add) are clean. Destruction acts fail because refusal is ONE monosemantic feature (#566) — category-agnostic.
      </p>
    </div>
  </section>

  {/* Tiers */}
  <section id="tiers" class="section-standard">
    <div class="reading wide">
      <h2>The Three Claim-Tiers</h2>
      <p class="lead">Kept strictly separate to prevent overreach.</p>
      <div style="margin-top: 2rem;">
        <TierMatrix />
      </div>
    </div>
  </section>

  {/* Debate */}
  <section id="debate" class="section-standard">
    <div class="reading wide">
      <h2>Debate & Convergent Hardening</h2>
      <p class="lead">Adversarial review → convergent rigor checks → honest reframe.</p>
      <div style="margin-top: 2rem; padding: 1.5rem; background: var(--bg-elevated); border-radius: 8px; border-left: 4px solid var(--violet);">
        <h3 style="margin-top: 0; font-size: 1.2rem;">F17: Convergent Rigor</h3>
        <ul style="font-size: 0.95rem; line-height: 1.8;">
          <li><strong>F13 Circularity (REFUTED):</strong> SAE feature orthogonal to direction (cos=0.002).</li>
          <li><strong>F11 Attenuation (DEMOTED):</strong> Symmetry within-domain, attenuated cross-domain.</li>
          <li><strong>F1 Replication (HOLDS):</strong> Multi-seed ASR [0.96, 0.75, 1.0], CI [0.83, 0.96].</li>
        </ul>
      </div>
    </div>
  </section>

  {/* Findings */}
  <section id="findings" class="section-standard">
    <div class="reading wide">
      <h2>Findings (F1–F18)</h2>
      <p class="lead">Filterable by tier and verdict.</p>
      <div style="margin-top: 2rem;">
        <FindingsExplorer client:visible findings={findings} />
      </div>
    </div>
  </section>

  {/* Reproducibility */}
  <section id="reproducibility" class="section-standard">
    <div class="reading">
      <h2>Reproducibility & Artifacts</h2>
      <ul style="font-size: 0.95rem; line-height: 1.8;">
        <li><strong>GitHub:</strong> <a href="https://github.com/SharathSPhD/prayoga" target="_blank">SharathSPhD/prayoga</a></li>
        <li><strong>HF Space (demo):</strong> <a href="https://huggingface.co/spaces/qbz506/prayoga" target="_blank">qbz506/prayoga</a></li>
        <li><strong>HF Dataset:</strong> <a href="https://huggingface.co/datasets/qbz506/prayoga-results" target="_blank">qbz506/prayoga-results</a></li>
        <li><strong>Colab:</strong> <a href="https://colab.research.google.com/github/SharathSPhD/prayoga/blob/main/notebooks/00_explore_results.ipynb" target="_blank">reproduce the results</a></li>
        <li><strong>Plugin:</strong> <a href="https://github.com/SharathSPhD/prayoga/tree/main/plugin" target="_blank">prayoga Claude Code plugin</a></li>
      </ul>
    </div>
  </section>

  {/* About */}
  <section id="about" class="section-standard">
    <div class="reading">
      <h2>About</h2>
      <p><strong>prayoga</strong> investigates LLM refusal mechanisms through mechanistic interpretability.</p>
      <p style="margin-top: 1rem;"><strong>Author:</strong> {AUTHOR.name} · <a href={`mailto:${AUTHOR.email}`}>{AUTHOR.email}</a></p>
      <p style="margin-top: 0.6rem; font-size: 0.9rem;">
        {socialLinks.map((l, i) => (<>{i > 0 ? ' · ' : ''}<a href={l.href} target="_blank" rel="noopener">{l.label}</a></>))}
      </p>
    </div>
  </section>
</Layout>

<style>
  .section-standard {
    background: var(--bg);
    border-bottom: 1px solid var(--hairline);
  }

  .triptych {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .triptych-panel {
    padding: 1.5rem;
    background: var(--bg-panel);
    border: 1px solid var(--hairline);
    border-radius: 8px;
    transition: all 0.2s;
  }

  .triptych-panel:hover {
    border-color: var(--cyan);
    box-shadow: 0 0 12px rgba(34, 211, 238, 0.15);
  }

  .triptych-panel h3 {
    margin-top: 0;
    font-size: 1.2rem;
  }
</style>
