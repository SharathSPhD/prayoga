---
const base = import.meta.env.BASE_URL;
---

<header class="site-header">
  <div class="header-inner">
    <a href={base} class="logo" aria-label="prayoga home">
      <span class="logo-text">prayoga</span>
    </a>
    <nav class="header-nav">
      <a href={`${base}#mechanism`}>Mechanism</a>
      <a href={`${base}#findings`}>Findings</a>
      <a href={`${base}#about`}>About</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
    border-bottom: 1px solid var(--hairline);
    backdrop-filter: blur(12px);
    background-color: rgba(10, 14, 20, 0.8);
  }

  .header-inner {
    max-width: var(--maxw-wide);
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--cyan);
    border: none;
    transition: color 0.2s;
  }

  .logo:hover {
    color: var(--violet);
  }

  .logo-text {
    background: linear-gradient(135deg, var(--cyan), var(--violet));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .header-nav {
    display: flex;
    gap: 2rem;
  }

  .header-nav a {
    font-size: 0.95rem;
    color: var(--ink-soft);
    border: none;
    transition: color 0.2s;
  }

  .header-nav a:hover {
    color: var(--cyan);
  }

  @media (max-width: 640px) {
    .header-inner {
      padding: 0.8rem 1.25rem;
    }
    .header-nav {
      gap: 1rem;
      font-size: 0.85rem;
    }
  }
</style>
