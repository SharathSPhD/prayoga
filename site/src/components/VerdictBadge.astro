---
export interface Props {
  verdict: 'holds' | 'supported' | 'falsified' | 'partial';
}

const { verdict } = Astro.props;

const verdictStyles = {
  holds: 'bg-emerald-900/50 border-emerald-700 text-emerald-100',
  supported: 'bg-blue-900/50 border-blue-700 text-blue-100',
  falsified: 'bg-rose-900/50 border-rose-700 text-rose-100',
  partial: 'bg-yellow-900/50 border-yellow-700 text-yellow-100',
};

const verdictLabel = {
  holds: 'HOLDS',
  supported: 'SUPPORTED',
  falsified: 'FALSIFIED',
  partial: 'PARTIAL',
};
---

<span class={`inline-flex items-center border rounded-full font-semibold px-3 py-1.5 text-sm ${verdictStyles[verdict]}`}>
  {verdictLabel[verdict]}
</span>
