---
export interface Props {
  verdict: 'holds' | 'supported' | 'falsified' | 'partial' | 'qualified' | 'pilot' | 'reframe' | 'demoted';
}

const { verdict } = Astro.props;

const verdictStyles: Record<string, string> = {
  holds: 'bg-emerald-900/50 border-emerald-700 text-emerald-100',
  supported: 'bg-blue-900/50 border-blue-700 text-blue-100',
  falsified: 'bg-rose-900/50 border-rose-700 text-rose-100',
  partial: 'bg-yellow-900/50 border-yellow-700 text-yellow-100',
  qualified: 'bg-teal-900/50 border-teal-700 text-teal-100',
  pilot: 'bg-indigo-900/50 border-indigo-700 text-indigo-100',
  reframe: 'bg-amber-900/50 border-amber-700 text-amber-100',
  demoted: 'bg-rose-900/50 border-rose-700 text-rose-100',
};

const verdictLabel: Record<string, string> = {
  holds: 'HOLDS',
  supported: 'SUPPORTED',
  falsified: 'FALSIFIED',
  partial: 'PARTIAL',
  qualified: 'QUALIFIED',
  pilot: 'PILOT',
  reframe: 'REFRAME',
  demoted: 'DEMOTED',
};

const fallback = 'bg-slate-800/50 border-slate-600 text-slate-200';
const style = verdictStyles[verdict] ?? fallback;
const label = verdictLabel[verdict] ?? String(verdict).toUpperCase();
---

<span class={`inline-flex items-center border rounded-full font-semibold px-3 py-1.5 text-sm ${style}`}>
  {label}
</span>
