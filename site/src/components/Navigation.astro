---
const navItems = [
  { href: '/prayoga/', label: 'Home' },
  { href: '/prayoga/mechanism', label: 'Mechanism' },
  { href: '/prayoga/vasikarana', label: 'Vaśīkaraṇa' },
  { href: '/prayoga/three-tiers', label: 'Three Tiers' },
  { href: '/prayoga/debate', label: 'Debate' },
  { href: '/prayoga/findings', label: 'Findings' },
  { href: '/prayoga/reproducibility', label: 'Reproducibility' },
  { href: '/prayoga/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<nav class="sticky top-0 z-50 border-b border-slate-800 bg-slate-950/95 backdrop-blur">
  <div class="max-w-6xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <a href="/prayoga/" class="font-serif font-bold text-2xl hover:text-slate-200 transition-colors">
        prayoga
      </a>
      <div class="hidden md:flex gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`text-sm transition-colors ${
              currentPath === item.href
                ? 'text-slate-100 border-b-2 border-blue-400'
                : 'text-slate-400 hover:text-slate-200'
            }`}
          >
            {item.label}
          </a>
        ))}
      </div>
      <div class="md:hidden">
        <button class="text-slate-400 hover:text-slate-200">☰</button>
      </div>
    </div>
  </div>
</nav>
